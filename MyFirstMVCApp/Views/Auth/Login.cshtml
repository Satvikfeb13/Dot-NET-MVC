@using MyFirstMVCApp.DTO 
@model UserDto
<div>@ViewBag.Message</div>
<form class="container d-flex justify-content-center align-items-center vh-100" method="post" asp-action="LoginUser">
    <div class="card p-4 shadow" style="width: 350px;">
        <h3 class="text-center mb-4">Login</h3>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" class="form-control" placeholder="Enter your email"  asp-for="Email">
            <span asp-validation-for="Email" class="text-danger"></span>

        </div>

        <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" class="form-control" placeholder="Enter your password" asp-for="Password">
            <span asp-validation-for="Password" class="text-danger"></span>

        </div>

        <div class="d-grid">
            <button class="btn btn-primary">Submit</button>
        </div>
    </div>
</form>

New User? Register <a asp-action="LoginToRegister">Here</a>
@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}